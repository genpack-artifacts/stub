# Enable AF_VSOCK guest support so `ssh root@vsock%$(vm cid stub)` works from the
# host. The paravirt profile already provides sshd-over-vsock on the guest; the
# kernel just needs the AF_VSOCK core plus the virtio (guest) transport. QEMU is
# launched with -device vhost-vsock-pci, so this is the guest side.
#
# (unset.config used to carry `# CONFIG_VSOCKETS is not set`, which silently
# disabled this once genpack's kernel/config.d mechanism started actually
# applying; that line has been removed and vsock is enabled explicitly here.)
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y
